{
  "name": "typediagram-core",
  "version": "0.0.0-dev",
  "description": "A small DSL for diagramming algebraic data types (records + tagged unions). Language-neutral. No methods.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nimblesite/typeDiagram.git",
    "directory": "packages/typediagram"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "import": "./dist/model/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js"
    },
    "./render-svg": {
      "types": "./dist/render-svg/index.d.ts",
      "import": "./dist/render-svg/index.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js"
    },
    "./converters/rust-tdbin": {
      "types": "./dist/converters/rust-tdbin.d.ts",
      "import": "./dist/converters/rust-tdbin.js"
    },
    "./converters/typescript-tdbin": {
      "types": "./dist/converters/typescript-tdbin.d.ts",
      "import": "./dist/converters/typescript-tdbin.js"
    },
    "./tdbin": {
      "types": "./dist/tdbin/index.d.ts",
      "import": "./dist/tdbin/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --coverage",
    "test:typeshed": "npm run build && node scripts/typeshed-corpus.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "check-banned-deps": "node scripts/check-banned-deps.mjs",
    "bundle-size": "node scripts/bundle-size.mjs",
    "check": "npm run check-banned-deps && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@lezer/python": "^1.1.19",
    "elkjs": "^0.11.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "typescript": "^7.0.2",
    "typescript-compiler": "npm:typescript@6.0.3",
    "vitest": "^4.1.10"
  }
}
