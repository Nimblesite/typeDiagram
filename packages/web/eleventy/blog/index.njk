---
layout: base.njk
tags: []
permalink: /blog/index.html
title: "Blog — typeDiagram"
description: "Updates, deep dives, and release notes from the typeDiagram team."
stylesHref: /src/styles.css
navLogoLink: /
navPlaygroundHref: /#playground
navConverterHref: /converter.html
navDocsHref: /docs/
navBlogHref: /blog/
---
<main class="main-content">
  <header class="hero">
    <h1 class="hero-title"><span class="hero-accent">Blog</span></h1>
    <p class="hero-sub">Updates, deep dives, and release notes.</p>
  </header>
  <section class="features">
    <div class="features-inner">
      <ul class="docs-nav">
        {% for post in collections.post | reverse %}
          {% if post.url != page.url %}
            <li>
              <a href="{{ post.url }}">{{ post.data.title }}</a>
              <small> — {{ post.date | isoDate }}</small>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </section>
</main>
